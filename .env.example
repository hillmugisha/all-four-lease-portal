# Supabase – copy these from your project's Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase "publishable key" (formerly anon key) – safe for browser use
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
# Supabase "secret key" (formerly service_role) – server-side ONLY, never prefix with NEXT_PUBLIC_
SUPABASE_SECRET_KEY=your-secret-key-here

# DocuSign – leave blank until Phase 2
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_PRIVATE_KEY=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
